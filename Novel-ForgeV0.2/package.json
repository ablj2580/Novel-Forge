{
  "name": "novel-forge-demo",
  "version": "0.1.0",
  "private": true,
  "description": "AI-assisted novel idea organizer and writing workspace demo.",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "build:nsis": "electron-builder --win nsis",
    "check": "node --check server.js && node --check electron-main.js"
  },
  "keywords": [
    "novel",
    "writing",
    "ai",
    "organizer"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.moxia.novelforge",
    "productName": "墨匣",
    "asar": true,
    "files": [
      "electron-main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "src/**/*",
      "styles/**/*",
      "mobile/**/*",
      "docs/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "signingHashAlgorithms": [],
      "sign": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
